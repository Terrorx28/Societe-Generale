# Hugging Face API key for LLM investigation summaries (RECOMMENDED)
# Get free key: https://huggingface.co/settings/tokens
# Without this, the system will use rule-based fallback investigations
HF_API_KEY=HF_TOKEN=your_token_here

# Optional: OpenAI API key as fallback (if HF key not set)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
